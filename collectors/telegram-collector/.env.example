# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=XXX
INSTANCE_ID=sales          # Logical name of this bot instance (sales | support | main | ...)

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ── Mode ──────────────────────────────────────────────────────────────────────
MODE=polling               # polling (local dev) | webhook (production)

# ── Webhook (only needed when MODE=webhook) ───────────────────────────────────
WEBHOOK_HOST=https://yourdomain.com
WEBHOOK_PATH=/webhook/telegram
SECRET_TOKEN=your_random_secret_here   # optional but recommended

# ── Servers ───────────────────────────────────────────────────────────────────
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8000           # Bot webhook server (MODE=webhook only)
HEALTH_PORT=8001           # Health-check server (always on, both modes)
